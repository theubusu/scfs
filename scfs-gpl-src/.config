#
# config file for gpl source code of bdre7g
#

CROSS = mips-sony-linux-dev-

ARCH_ENV      = /usr/local/mips-sony-linux
INSTROOT     ?= $(ARCH_ENV)/target
COMP_PLUGIN  ?= lzo
ENC_PLUGIN   ?=
HOST_TOOLS   ?=
TARGET_TOOLS ?=

#
# For tool
#
HOST_TOOL_CFLAGS = $(COMMON_TOOL_CFLAGS) -D_LARGEFILE_SOURCE

#
# For KBUILD
#
# kbuild path
KBUILD		?= $(ARCH_ENV)/kbuild

export CROSS ARCH_ENV INSTROOT COMP_PLUGIN ENC_PLUGIN
export KBUILD
